# Phase 1 defaults: no API keys are required.
AUTORAG_EMBEDDING_MODE=tfidf

# Optional LLM keys. If absent, AutoRAG 360 uses cited extractive answers.
GROQ_API_KEY=
GEMINI_API_KEY=

# Retained as a placeholder for future providers. Phase 3 generation uses Groq and Gemini.
OPENAI_API_KEY=

# Set this only when you replace the bundled/generated CSVs with real data.
AUTORAG_USE_REAL_NHTSA=false
